# ═══════════════════════════════════════════════════════════════
# PULSAR STUDIO — Environment Variables
# Copy this file: cp .env.example .env
# Then fill in your real values
# ═══════════════════════════════════════════════════════════════

# ── GCP Project ─────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=pulsar-studio-prod
GOOGLE_APPLICATION_CREDENTIALS=~/.config/gcloud/pulsar-sa.json

# ── Cloud Storage ───────────────────────────────────────────────
BUCKET_NAME=pulsar-studio-assets

# ── Pub/Sub ─────────────────────────────────────────────────────
PUBSUB_TOPIC=pulsar-jobs

# ── Region ──────────────────────────────────────────────────────
REGION=us-central1

# ── Ports ───────────────────────────────────────────────────────
# PORT=8080          # Node A (default)
# PORT=8081          # Node B
# AIP_HTTP_PORT=8082 # Node C (Vertex AI format)

# ── Local Development ──────────────────────────────────────────
# Set to 1 to skip GCS/Pub/Sub and use local filesystem
LOCAL_MOCK=0
LOCAL_JOBS_DIR=./tmp/jobs

# ── Watermark ──────────────────────────────────────────────────
WATERMARK_ENABLED=1
WATERMARK_TEXT=PULSAR STUDIO
WATERMARK_POSITION=bottom
# WATERMARK_PNG_GCS_URI=gs://pulsar-studio-assets/watermarks/default.png
# WATERMARK_OPACITY=0.25
# WATERMARK_SAFE_MARGIN=300
